{
  "name": "edgevox-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-docs": "node -e \"const fs=require('fs'),p=require('path');fs.readdirSync('docs').filter(f=>f!=='.vitepress').forEach(f=>{const fp=p.join('docs',f);fs.rmSync(fp,{recursive:true,force:true})});\" && cp -r ../docs/* docs/",
    "dev": "npm run sync-docs && vitepress dev docs",
    "build": "npm run sync-docs && vitepress build docs",
    "preview": "vitepress preview docs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
