{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EdgeVox",
  "version": "0.1.0",
  "identifier": "ai.edgevox.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EdgeVox",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Offline voice agent desktop app",
    "longDescription": "EdgeVox is an offline voice agent for robots. This desktop shell bundles the WebSocket server and UI into a native app."
  }
}
